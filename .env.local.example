# s4skillup Environment Configuration
# Copy this file to .env.local and fill in your actual values

# FOR PRODUCTION: Use Vercel Environment Variables Dashboard instead
# https://vercel.com/dashboard/[project]/settings/environment-variables

# ==================== CORE SETUP ====================
VITE_ENVIRONMENT=development
VITE_API_BASE_URL=http://localhost:3000
VITE_APP_URL=http://localhost:5173

# ==================== DATABASE (Supabase) ====================
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ==================== EMAIL SERVICE (Resend) ====================
RESEND_API_KEY=re_your_api_key_here

# ==================== ERROR TRACKING (Sentry) ====================
VITE_SENTRY_DSN=https://your-key@sentry.io/project-id
SENTRY_AUTH_TOKEN=your-auth-token

# ==================== ANALYTICS (PostHog) ====================
VITE_POSTHOG_API_KEY=phc_your_api_key
VITE_POSTHOG_API_HOST=https://us.posthog.com

# ==================== AI/LLM (OpenAI or Gemini) ====================
OPENAI_API_KEY=sk-your-key-here
VITE_GEMINI_API_KEY=your-gemini-key-here

# ==================== PAYMENTS (Razorpay - India) ====================
VITE_RAZORPAY_KEY_ID=rzp_your_key_id
RAZORPAY_KEY_SECRET=your_key_secret

# ==================== STORAGE (Vercel Blob or S3) ====================
BLOB_READ_WRITE_TOKEN=your-token
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_S3_BUCKET=s4skillup-bucket

# ==================== DATA SCRAPING (Apify) ====================
APIFY_API_TOKEN=your-apify-token

# ==================== LOGGING ====================
LOG_LEVEL=debug

# ==================== FEATURE FLAGS (PostHog) ====================
VITE_ENABLE_MATCH_SCORE=true
VITE_ENABLE_SUCCESS_STORIES=true
VITE_ENABLE_SALARY_BENCHMARKS=true
